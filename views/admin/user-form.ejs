<%- include('_header', { pageTitle: 'Редактировать пользователя' }) %>

    <div class="admin-header">
        <h1>Редактировать пользователя</h1>
        <p><a href="/admin/users" style="color: rgba(255,255,255,0.4); text-decoration: none;">← Назад к списку пользователей</a></p>
    </div>

    <div class="form-card">
        <% if (error) { %>
            <div class="error-box">
                <%= error %>
            </div>
        <% } %>

        <form method="POST" action="/admin/users/<%= managedUser.id %>/edit">
            <div class="form-group">
                <label>Никнейм</label>
                <input
                    type="text"
                    name="username"
                    class="form-control"
                    required
                    value="<%= managedUser.username %>"
                    placeholder="Введите никнейм"
                >
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Роль</label>
                    <select name="role" class="form-control" <%= managedUser.id === user.id ? 'disabled' : '' %>>
                        <option value="user" <%= managedUser.role === 'user' ? 'selected' : '' %>>Пользователь</option>
                        <option value="admin" <%= managedUser.role === 'admin' ? 'selected' : '' %>>Администратор</option>
                    </select>
                    <% if (managedUser.id === user.id) { %>
                        <div style="margin-top: 10px; color: rgba(255,255,255,0.45); font-size: 13px;">Свою роль можно только просматривать.</div>
                        <input type="hidden" name="role" value="admin">
                    <% } %>
                </div>
                <div class="form-group">
                    <label>ID пользователя</label>
                    <input type="text" class="form-control" value="<%= managedUser.id %>" disabled>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Уровень</label>
                    <input type="text" class="form-control" value="<%= managedUser.level %>" disabled>
                </div>
                <div class="form-group">
                    <label>Опыт</label>
                    <input type="text" class="form-control" value="<%= managedUser.exp %> EXP" disabled>
                </div>
            </div>

            <div style="display: flex; gap: 12px; margin-top: 8px; flex-wrap: wrap;">
                <button type="submit" class="btn btn-primary">Сохранить изменения</button>
                <a href="/admin/users" class="btn btn-ghost">Отмена</a>
            </div>
        </form>

        <% if (managedUser.id !== user.id) { %>
            <div style="margin-top: 28px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1);">
                <form method="POST" action="/admin/users/<%= managedUser.id %>/delete" onsubmit="return confirm('Удалить пользователя <%= managedUser.username %>? Это действие нельзя отменить.')">
                    <button type="submit" class="btn btn-danger">Удалить аккаунт</button>
                </form>
            </div>
        <% } %>
    </div>

<%- include('_footer') %>