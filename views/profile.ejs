<!DOCTYPE html>
<html lang="ru">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Профиль - CitiVoice</title>

  <link rel="stylesheet" href="/css/spatial.css">
  <style>
    body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
    }

    .profile-master-container {
        width: 100%;
        max-width: 900px; /* Шире, чтобы вместить больше контента */
        display: flex;
        margin-top: 80px;
        border-radius: 36px;
        overflow: hidden;
    }

    .profile-left {
        flex: 1;
        padding: 50px 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        background: rgba(20, 20, 25, 0.4);
    }

    .profile-right {
        flex: 1.2;
        padding: 50px 40px;
        background: rgba(0, 0, 0, 0.4);
        border-left: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* Left Side: Avatar & Info */
    .profile-avatar {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02));
        border: 2px solid var(--accent);
        box-shadow: 0 0 30px rgba(224, 255, 79, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        position: relative;
    }

    .profile-avatar .level-text {
        font-size: 3.5rem;
        font-weight: 800;
        color: var(--accent);
        line-height: 1;
    }

    .level-badge {
        position: absolute;
        bottom: -10px;
        background: var(--accent);
        color: #000;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: bold;
        letter-spacing: 1px;
    }

    .profile-name {
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0 0 5px 0;
    }

    .profile-role {
        color: rgba(255, 255, 255, 0.5);
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 30px;
    }

    .action-buttons {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 30px;
    }

    .btn-profile {
        width: 100%;
        padding: 14px;
        border-radius: 14px;
        font-weight: 600;
        text-align: center;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .btn-play { background: var(--accent); color: #000; }
    .btn-play:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(224, 255, 79, 0.3); }
    
    .btn-logout { background: rgba(255, 255, 255, 0.05); color: #fff; border: 1px solid rgba(255,255,255,0.1); }
    .btn-logout:hover { background: rgba(255, 70, 70, 0.1); color: #FF5A5A; border-color: rgba(255, 70, 70, 0.2); }

    /* Right Side: Stats & Progress */
    .section-title {
        font-size: 1rem;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 15px;
        margin-top: 0;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-bottom: 35px;
    }

    .stat-box {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 20px;
        border-radius: 16px;
    }

    .stat-box .val {
        font-size: 1.8rem;
        font-weight: bold;
        color: var(--accent);
        margin-bottom: 5px;
        line-height: 1;
    }

    .stat-box .lbl {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.5);
        text-transform: uppercase;
    }

    .progress-wrap {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 24px;
        border-radius: 16px;
        margin-bottom: 35px;
    }

    .progress-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 12px;
        font-size: 0.95rem;
    }

    .level-bar {
        height: 6px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
        overflow: hidden;
    }

    .level-fill {
        height: 100%;
        background: var(--accent);
        box-shadow: 0 0 15px var(--accent);
        transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Achievements / Badges */
    .badges-row {
        display: flex;
        gap: 15px;
    }

    .badge-item {
        flex: 1;
        aspect-ratio: 1;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 10px;
        transition: all 0.3s;
    }
    
    .badge-icon {
        width: 32px;
        height: 32px;
        color: var(--accent);
    }

    .badge-locked {
        opacity: 0.2;
        filter: grayscale(1);
    }

    .badge-label {
        font-size: 0.7rem;
        text-align: center;
        color: rgba(255,255,255,0.6);
        font-weight: 600;
        text-transform: uppercase;
    }

    @media (max-width: 768px) {
        .profile-master-container { flex-direction: column; }
        .profile-right { border-left: none; border-top: 1px solid rgba(255,255,255,0.05); }
    }
  </style>
</head>

<body>

  <div class="spatial-video-bg">
    <video autoplay muted loop playsinline>
      <source src="/images/Russia%20in%204K%20-%20Incredible%20Scenes%20Hidden%20Gems%20%5Bget.gt%5D.mp4" type="video/mp4">
    </video>
  </div>
  <div class="spatial-vignette"></div>

  <nav class="spatial-nav glass-panel">
    <div class="nav-brand">
      <a href="/" style="display:flex; align-items:center; gap:12px; text-decoration:none; color:inherit;">
        <img src="/images/logo-icon.png" alt="Logo" style="height:24px;"> CitiVoice
      </a>
    </div>
    <div class="nav-links">
      <a href="/places">Места</a>
      <a href="/routes">Маршруты</a>
      <a href="/game">Игра</a>
      <a href="/map">Карта</a>
      <% if (locals.user && locals.user.role === 'admin') { %>
        <a href="/admin" style="color: #E0FF4F; font-weight: 600;">Админ</a>
      <% } %>
    </div>
    <div class="nav-user">
      <a href="/profile" style="color: inherit;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>
        </svg>
      </a>
    </div>
  </nav>

  <!-- SPLIT DOSSIER CARD -->
  <div class="glass-panel profile-master-container">
      
      <!-- LEFT: IDENTITY -->
      <div class="profile-left">
          <div class="profile-avatar">
              <div class="level-text"><%= user.level %></div>
              <div class="level-badge">УРОВЕНЬ</div>
          </div>
          <h1 class="profile-name"><%= user.username %></h1>
          <div class="profile-role"><%= user.level >= 10 ? 'Городская легенда' : (user.level >= 5 ? 'Опытный исследователь' : 'Начинающий турист') %></div>
          
          <div class="action-buttons">
              <a href="/game" class="btn-profile btn-play">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                  Искать маркеры
              </a>
              <a href="/" class="btn-profile btn-logout" style="margin-top: -5px;">На главную</a>
              <a href="/logout" class="btn-profile btn-logout" style="margin-top: -5px;">Выйти из аккаунта</a>
          </div>
      </div>

      <!-- RIGHT: DOSSIER DATA -->
      <div class="profile-right">
          
          <h3 class="section-title">Статистика</h3>
          <div class="stats-grid">
              <div class="stat-box">
                  <div class="val"><%= user.exp %></div>
                  <div class="lbl">Всего опыта</div>
              </div>
              <div class="stat-box">
                  <div class="val" style="color: #fff; font-size: 1.4rem; padding-top: 5px;"><%= user.role === 'admin' ? 'Админ' : 'Игрок' %></div>
                  <div class="lbl" style="margin-top: 3px;">Права доступа</div>
              </div>
          </div>

          <h3 class="section-title">Прогресс</h3>
          <div class="progress-wrap">
              <div class="progress-header">
                  <span>До <%= user.level + 1 %> уровня</span>
                  <span style="color: var(--accent); font-weight: 600;"><%= user.exp - ((user.level - 1) * 100) %> / 100 EXP</span>
              </div>
              <div class="level-bar">
                  <div class="level-fill" style="width: <%= progressPercent %>%;"></div>
              </div>
              <div style="font-size: 0.8rem; color: rgba(255,255,255,0.4); margin-top: 12px; text-align: right;">
                  Осталось <%= nextRankExp %> очков
              </div>
          </div>

          <h3 class="section-title">Достижения</h3>
          <div class="badges-row">
              <div class="badge-item">
                  <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                  <span class="badge-label">Новичок</span>
              </div>
              <div class="badge-item <%= user.level < 5 ? 'badge-locked' : '' %>">
                  <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
                  <span class="badge-label">Знаток</span>
              </div>
              <div class="badge-item <%= user.level < 10 ? 'badge-locked' : '' %>">
                  <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                  <span class="badge-label">Легенда</span>
              </div>
          </div>

      </div>

  </div>

</body>
</html>