<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Маршруты CitiVoice</title>
    <link rel="stylesheet" href="/css/spatial.css">
    <style>
        body {
            background-color: #050505;
            color: #fff;
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", sans-serif;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        .page-bg {
            position: fixed;
            inset: -20%;
            width: 140%;
            height: 140%;
            z-index: -2;
            background-image:
                radial-gradient(circle at 20% 40%, rgba(224, 255, 79, 0.12), transparent 40%),
                radial-gradient(circle at 80% 70%, rgba(41, 128, 185, 0.12), transparent 40%);
            background-color: #050505;
            filter: blur(80px);
            animation: breathe 15s ease-in-out infinite alternate;
        }

        @keyframes breathe {
            0% {
                transform: scale(1);
                opacity: 0.8;
            }

            100% {
                transform: scale(1.1);
                opacity: 1;
            }
        }

        .spatial-nav {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1000;
        }

        .hero-section {
            padding: 160px 40px 60px;
            text-align: center;
            max-width: 800px;
            margin: 0 auto;
        }

        .hero-title {
            font-size: 5rem;
            font-weight: 900;
            letter-spacing: -2px;
            margin: 0 0 20px 0;
            background: linear-gradient(180deg, #fff 0%, rgba(255, 255, 255, 0.5) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-subtitle {
            font-size: 1.25rem;
            color: rgba(255, 255, 255, 0.6);
            line-height: 1.6;
        }

        .routes-grid {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 40px 100px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(450px, 1fr));
            gap: 30px;
        }

        .route-bento {
            position: relative;
            height: 480px;
            border-radius: 40px;
            overflow: hidden;
            text-decoration: none;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            border: 1px solid rgba(255, 255, 255, 0.05);
            background: #111;
        }

        .route-bento:hover {
            transform: scale(1.02) translateY(-10px);
            border-color: rgba(224, 255, 79, 0.3);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.7), 0 0 40px rgba(224, 255, 79, 0.05);
            z-index: 10;
        }

        .route-bg {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center;
            transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
            z-index: 1;
            filter: brightness(0.9);
        }

        .route-bento:hover .route-bg {
            transform: scale(1.08);
            filter: brightness(1);
        }

        .route-gradient {
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, transparent 0%, rgba(10, 10, 12, 0.95) 100%);
            z-index: 2;
        }

        .route-content {
            position: relative;
            z-index: 3;
            padding: 35px;
        }

        .route-meta {
            display: flex;
            gap: 12px;
            margin-bottom: 16px;
            color: #E0FF4F;
            font-weight: 700;
            font-size: 13px;
        }

        .route-meta span {
            display: flex;
            align-items: center;
            gap: 6px;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(10px);
            padding: 8px 14px;
            border-radius: 100px;
            border: 1px solid rgba(224, 255, 79, 0.2);
        }

        .route-title {
            margin: 0 0 12px 0;
            font-size: 2.2rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.1;
        }

        .route-desc {
            margin: 0;
            color: rgba(255, 255, 255, 0.7);
            font-size: 15px;
            line-height: 1.6;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        @media (max-width: 768px) {
            .routes-grid {
                grid-template-columns: 1fr;
            }

            .hero-title {
                font-size: 3.5rem;
            }
        }
    </style>
</head>

<body>
    <div class="page-bg"></div>

    <nav class="spatial-nav glass-panel">
        <div class="nav-brand">
            <a href="/" style="display:flex; align-items:center; gap:12px; text-decoration:none; color:inherit;">
                <img src="/images/logo-icon.png" alt="Logo" style="height:24px;">
                CitiVoice
            </a>
        </div>
        <div class="nav-links">
            <a href="/places">Места</a>
            <a href="/routes">Маршруты</a>
            <a href="/game">Игра</a>
            <a href="/map">Карта</a>
            <% if (locals.user && locals.user.role==='admin' ) { %>
                <a href="/admin" style="color: #E0FF4F; font-weight: 600;">Админ</a>
                <% } %>
        </div>
        <div class="nav-user">
            <a href="<%= locals.user ? '/profile' : '/login' %>" style="color: inherit;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg>
            </a>
        </div>
    </nav>

    <div class="hero-section">
        <h1 class="hero-title">Маршруты</h1>
        <p class="hero-subtitle">Уникальные авторские прогулки по городу. Откройте для себя знакомые улицы совершенно
            заново.</p>
    </div>

    <div class="routes-grid">
        <% if (routes && routes.length> 0) { %>
            <% routes.forEach(route=> { %>
                <a href="/routes/<%= route.id %>" class="route-bento">
                    <div class="route-bg"
                        style="background-image: url('<%= route.image || 'https://images.unsplash.com/photo-1542273917363-3b1817f69a5d?w=800&q=80' %>')">
                    </div>
                    <div class="route-gradient"></div>
                    <div class="route-content">
                        <div class="route-meta">
                            <span>
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <polyline points="12 6 12 12 16 14"></polyline>
                                </svg>
                                <%= route.duration %>
                            </span>
                            <span>
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z">
                                    </path>
                                    <circle cx="12" cy="9" r="2.5"></circle>
                                </svg>
                                <%= route.distance %>
                            </span>
                        </div>
                        <h2 class="route-title">
                            <%= route.title %>
                        </h2>
                        <p class="route-desc">
                            <%= route.description %>
                        </p>
                    </div>
                </a>
                <% }) %>
                    <% } else { %>
                        <div
                            style="grid-column: 1/-1; text-align: center; color: rgba(255,255,255,0.4); padding: 60px;">
                            Маршруты пока не добавлены.
                        </div>
                        <% } %>
    </div>
</body>

</html>