<!DOCTYPE html>
<html lang="ru">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>

  <!-- We use our brand new Spatial Dashboard CSS -->
  <link rel="stylesheet" href="/css/spatial.css">
</head>

<body>

  <!-- SPATIAL BACKGROUND -->
  <div class="spatial-video-bg">
    <video autoplay muted loop playsinline>
      <source src="/images/Russia%20in%204K%20-%20Incredible%20Scenes%20Hidden%20Gems%20%5Bget.gt%5D.mp4"
        type="video/mp4">
    </video>
  </div>
  <div class="spatial-vignette"></div>

  <!-- FLOATING NAVIGATION -->
  <nav class="spatial-nav glass-panel">
    <div class="nav-brand">
      <a href="/" style="display:flex; align-items:center; gap:12px; text-decoration:none; color:inherit;">
        <img src="/images/logo-icon.png" alt="Logo" style="height:24px;">
        CitiVoice
      </a>
    </div>
    <div class="nav-links">
      <a href="/places">Места</a>
      <a href="/routes">Маршруты</a>
      <a href="/game">Игра</a>
      <a href="/map">Карта</a>
      <% if (locals.user && locals.user.role==='admin' ) { %>
        <a href="/admin" style="color: #E0FF4F; font-weight: 600;">Админ</a>
        <% } %>
    </div>
    <div class="nav-user">
      <a href="<%= locals.user ? '/profile' : '/login' %>" style="color: inherit;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </a>
    </div>
  </nav>

  <!-- BENTO DASHBOARD -->
  <main class="spatial-dashboard">

    <!-- HERO CARD (Big Featured Story) -->
    <section class="glass-panel card-hero">
      <img src="/images/22_orenburg.jpg" alt="Оренбург" class="panel-bg-img">
      <div class="panel-content">
        <span class="panel-tag">Главная тема</span>
        <h1>Глубина Твоего Города.</h1>
        <p>Интерактивные маршруты, которые открывают знакомые улицы совершенно по-новому. Отправляйся в путешествие
          сегодня.</p>
        <div>
          <button class="btn-primary">Начать маршрут</button>
        </div>
      </div>
    </section>

    <!-- PROFILE / PROGRESS WIDGET -->
    <section class="glass-panel card-profile" style="cursor:pointer;" onclick="window.location.href='/profile'">
      <div class="panel-content">
        <div class="avatar">
          <%= locals.user ? locals.user.level : 1 %>
        </div>
        <h3>Уровень Исследователя</h3>
        <p>До следующего ранга: <%= locals.nextRankExp %> EXP</p>
        <div class="level-bar">
          <div class="level-fill" style="width: <%= locals.progressPercent %>%;"></div>
        </div>
      </div>
    </section>

    <!-- MAP WIDGET -->
    <section class="glass-panel card-map">
      <img src="/images/карта.png" alt="Карта" class="panel-bg-img" style="filter: contrast(1.2);">
      <div class="panel-content">
        <span class="panel-tag">Навигация</span>
        <h3>Интерактивная карта</h3>
        <p>Отметки мест, слои и фильтры по всему городу.</p>
        <a href="/map" class="btn-primary map-open-btn">Открыть &rarr;</a>
      </div>
    </section>

    <!-- GAME OVERVIEW WIDGET -->
    <section class="glass-panel card-journal" onclick="window.location.href='/game'" style="cursor:pointer;">
      <img src="/images/puteshestviya.jpg" alt="Игра" class="panel-bg-img" style="opacity: 0.25;">
      <div class="panel-content">
        <span class="panel-tag">Мини-игра</span>
        <h2>Сыграй с нами</h2>
        <p>Проверь свои знания Оренбурга и скорость реакции в нашей новой кибер-игре. Поймай все маркеры до истечения
          времени!</p>
      </div>
    </section>

    <!-- POPULAR LOCATIONS WIDGET -->
    <section class="glass-panel card-locations">
      <div class="panel-content">
        <span class="panel-tag">Популярное</span>
        <h3 style="margin:0 0 16px;">Интересные локации</h3>

        <style>
            .modern-loc-list {
              display: grid;
              grid-template-columns: repeat(4, 1fr);
              gap: 12px;
              width: 100%;
            }
            .modern-loc-item {
              position: relative;
              height: 120px;
              border-radius: 16px;
              overflow: hidden;
              cursor: pointer;
              border: 1px solid rgba(255, 255, 255, 0.08);
              transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s;
            }
            .modern-loc-item:hover {
              transform: translateY(-4px) scale(1.02);
              border-color: rgba(224, 255, 79, 0.4);
              box-shadow: 0 10px 20px rgba(0,0,0,0.5), 0 0 15px rgba(224, 255, 79, 0.15);
            }
            .modern-loc-img {
              width: 100%;
              height: 100%;
              object-fit: cover;
              transition: transform 0.5s ease;
            }
            .modern-loc-item:hover .modern-loc-img {
              transform: scale(1.1);
            }
            .modern-loc-overlay {
              position: absolute;
              inset: 0;
              background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 60%, rgba(0,0,0,0) 100%);
              display: flex;
              align-items: flex-end;
              padding: 12px;
            }
            .modern-loc-title {
              color: #fff;
              font-size: 13px;
              font-weight: 700;
              line-height: 1.3;
              font-family: inherit;
              text-shadow: 0 2px 5px rgba(0,0,0,0.8);
              display: -webkit-box;
              -webkit-line-clamp: 3;
              -webkit-box-orient: vertical;
              overflow: hidden;
            }
            @media (max-width: 768px) {
              .modern-loc-list {
                display: flex;
                overflow-x: auto;
                scroll-snap-type: x mandatory;
                padding-bottom: 10px;
              }
              .modern-loc-list::-webkit-scrollbar {
                display: none;
              }
              .modern-loc-item {
                flex: 0 0 130px;
                scroll-snap-align: start;
              }
            }
          </style>

          <div class="modern-loc-list">
            <% if (locals.popularPlaces && popularPlaces.length > 0) { %>
              <% popularPlaces.forEach(place => { %>
                <div class="modern-loc-item" onclick="window.location.href='/place/<%= place.id %>'">
                  <img src="<%= place.image || '/images/places.jpg' %>" alt="<%= place.title %>" class="modern-loc-img" onerror="this.src='/images/places.jpg'">
                  <div class="modern-loc-overlay">
                    <span class="modern-loc-title"><%= place.title %></span>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <p style="font-size: 13px; color: rgba(255,255,255,0.5);">Нет мест</p>
            <% } %>
          </div>

        </div>
      </section>

    <!-- WEATHER WIDGET -->
    <section class="glass-panel card-weather">
      <div class="panel-content" style="align-items: center; text-align: center; padding: 24px;">
        <span class="panel-tag" style="margin-bottom:auto;">Оренбург</span>
        <div id="weather-icon" style="font-size: 56px; line-height: 1; text-shadow: 0 10px 20px rgba(0,0,0,0.5);">☁️
        </div>
        <div id="weather-temp" class="weather-temp"
          style="font-size: 48px; font-weight: 800; line-height: 1.2; margin-top: 8px;">--°</div>
        <p id="weather-desc" style="margin: 0; font-size: 14px; color: rgba(255,255,255,0.6); margin-top: auto;">
          Загрузка...</p>
      </div>
    </section>

    <!-- RANDOM LOCATION -->
    <section class="glass-panel card-random" onclick="window.location.href='/places'">
      <div class="panel-content" style="align-items: center; text-align: center; padding: 24px;">
        <div
          style="width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, rgba(224,255,79,0.2), rgba(0,255,135,0.2)); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; border: 1px solid rgba(224,255,79,0.3); box-shadow: 0 0 20px rgba(224,255,79,0.1);">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#E0FF4F" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <circle cx="8.5" cy="8.5" r="1.5" fill="#E0FF4F"></circle>
            <circle cx="15.5" cy="15.5" r="1.5" fill="#E0FF4F"></circle>
            <circle cx="12" cy="12" r="1.5" fill="#E0FF4F"></circle>
          </svg>
        </div>
        <h3 style="margin:0 0 4px; font-size:20px;">Мне повезёт</h3>
        <p style="margin:0; font-size:14px; color:rgba(255,255,255,0.6);">Случайное место</p>
      </div>
    </section>

    <!-- AUDIO OF THE DAY -->
    <section class="glass-panel card-audio">
      <img src="/images/22_orenburg.jpg" alt="Audio bg" class="panel-bg-img"
        style="opacity: 0.15; filter: grayscale(100%);">
      <div class="panel-content" style="flex-direction: row; align-items: center; gap: 20px; padding: 32px;">
        <button class="play-btn"
          style="width: 64px; height: 64px; border-radius: 50%; background: #E0FF4F; border: none; cursor: pointer; display: flex; justify-content: center; align-items: center; flex-shrink: 0; box-shadow: 0 10px 20px rgba(224,255,79,0.3);">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="#000">
            <polygon points="8 6 18 12 8 18 8 6"></polygon>
          </svg>
        </button>
        <div style="flex: 1;">
          <span class="panel-tag" style="margin-bottom: 8px;">Аудиогид дня</span>
          <h3 style="margin: 0 0 6px; font-size: 22px; line-height: 1.1;">Тайны старого центра</h3>
          <p style="margin: 0; font-size: 14px; color: rgba(255,255,255,0.6);">Фрагмент • 2:45</p>
        </div>
        <div style="display: flex; gap: 4px; align-items: center; height: 40px;">
          <div class="sound-wave" style="width:4px; height:60%; background:rgba(255,255,255,0.3); border-radius:2px;">
          </div>
          <div class="sound-wave"
            style="width:4px; height:100%; background:#E0FF4F; border-radius:2px; box-shadow: 0 0 10px rgba(224,255,79,0.5);">
          </div>
          <div class="sound-wave" style="width:4px; height:40%; background:rgba(255,255,255,0.3); border-radius:2px;">
          </div>
          <div class="sound-wave" style="width:4px; height:80%; background:rgba(255,255,255,0.3); border-radius:2px;">
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="spatial-footer">
    <p>&copy; 2026 CitiVoice. Создано для городских исследователей.</p>
  </footer>

  <script>
    // Open-Meteo API Fetch for Orenburg
    async function fetchWeather() {
      try {
        const lat = 51.7682;
        const lon = 55.0970;
        const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true`;

        const response = await fetch(url);
        if (!response.ok) throw new Error('Network response was not ok');
        const data = await response.json();

        const temp = Math.round(data.current_weather.temperature);
        const code = data.current_weather.weathercode;

        let icon = '☁️';
        let desc = 'Облачно';

        if (code === 0) { icon = '☀️'; desc = 'Ясно'; }
        else if (code === 1 || code === 2 || code === 3) { icon = '⛅'; desc = 'Переменная облачность'; }
        else if (code >= 45 && code <= 48) { icon = '🌫️'; desc = 'Туман'; }
        else if (code >= 51 && code <= 67) { icon = '🌧️'; desc = 'Дождь'; }
        else if (code >= 71 && code <= 86) { icon = '❄️'; desc = 'Снег'; }
        else if (code >= 95) { icon = '⛈️'; desc = 'Гроза'; }

        document.getElementById('weather-temp').innerText = (temp > 0 ? '+' : '') + temp + '°';
        document.getElementById('weather-icon').innerText = icon;
        document.getElementById('weather-desc').innerText = desc;
      } catch (e) {
        document.getElementById('weather-desc').innerText = 'Нет данных';
      }
    }

    fetchWeather();
  </script>
</body>

</html>