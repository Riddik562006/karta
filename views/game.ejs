<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Игра-Квест CitiVoice</title>
    <link rel="stylesheet" href="/css/spatial.css">
    <style>
        html,
        body {
            height: 100%;
            margin: 0;
            overflow: hidden;
            background: #030303;
            font-family: 'Inter', sans-serif;
            color: #fff;
        }

        .game-bg {
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 20% 40%, rgba(224, 255, 79, 0.08), transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(41, 128, 185, 0.08), transparent 50%);
            background-image:
                linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
            background-size: 50px 50px;
            pointer-events: none;
            z-index: 0;
        }

        .spatial-nav {
            top: 20px;
            z-index: 1000;
        }

        .quest-container {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            max-width: 760px;
            padding: 20px;
            box-sizing: border-box;
            z-index: 10;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .score-panel {
            background: rgba(10, 10, 15, 0.65);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 14px 18px;
            text-align: left;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            align-self: stretch;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
        }

        .score-item {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            padding: 10px 12px;
        }

        .score-label {
            display: block;
            font-size: 12px;
            color: rgba(255, 255, 255, 0.65);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 6px;
        }

        .score-panel span,
        .score-value {
            color: #E0FF4F;
            font-weight: 800;
            font-size: 22px;
            text-shadow: 0 0 10px rgba(224, 255, 79, 0.4);
        }

        .progress-wrap {
            grid-column: 1 / -1;
            margin-top: 4px;
        }

        .progress-track {
            height: 8px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 999px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            width: 0;
            background: linear-gradient(90deg, #E0FF4F, #96c93d);
            box-shadow: 0 0 14px rgba(224, 255, 79, 0.5);
            transition: width 0.35s ease;
        }

        .progress-caption {
            margin-top: 8px;
            font-size: 13px;
            color: rgba(255, 255, 255, 0.72);
        }

        .quest-card {
            background: rgba(20, 20, 25, 0.7);
            backdrop-filter: blur(30px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 32px;
            padding: 34px;
            text-align: left;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
            transition: transform 0.4s ease, opacity 0.4s ease;
            min-height: 320px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .quest-card.fade {
            opacity: 0;
            transform: scale(0.95) translateY(10px);
        }

        .badge {
            display: inline-block;
            background: rgba(224, 255, 79, 0.1);
            color: #E0FF4F;
            padding: 6px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px;
            align-self: center;
            border: 1px solid rgba(224, 255, 79, 0.3);
        }

        .fact-text {
            font-size: 18px;
            line-height: 1.6;
            color: rgba(255, 255, 255, 0.9);
            margin-bottom: 30px;
            text-align: left;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 18px;
            padding: 18px;
        }

        .question-text {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 30px;
            line-height: 1.35;
        }

        .btn-action {
            background: #E0FF4F;
            color: #000;
            border: none;
            padding: 16px 32px;
            border-radius: 20px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.2s;
            align-self: center;
            box-shadow: 0 0 15px rgba(224, 255, 79, 0.4);
            margin-top: auto;
        }

        .btn-action:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 0 25px rgba(224, 255, 79, 0.7);
        }

        .options-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .option-btn {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 16px;
            border-radius: 16px;
            font-size: 16px;
            cursor: pointer;
            transition: 0.2s;
            text-align: left;
            line-height: 1.4;
            min-height: 74px;
            display: flex;
            align-items: center;
        }

        .option-btn:hover:not(:disabled) {
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }

        .option-btn:disabled {
            cursor: default;
        }

        .option-btn.correct {
            background: rgba(224, 255, 79, 0.2);
            border-color: #E0FF4F;
            color: #E0FF4F;
            box-shadow: 0 0 20px rgba(224, 255, 79, 0.3);
        }

        .option-btn.wrong {
            background: rgba(255, 79, 79, 0.2);
            border-color: #FF4F4F;
            color: #FF4F4F;
        }

        .result-message {
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 16px;
            margin-top: 0;
        }

        .result-message.success {
            color: #E0FF4F;
            text-shadow: 0 0 15px rgba(224, 255, 79, 0.5);
        }

        .result-message.fail {
            color: #FF4F4F;
            text-shadow: 0 0 15px rgba(255, 79, 79, 0.5);
        }

        .result-subtext {
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 30px;
            font-size: 16px;
        }

        .hero-title {
            margin: 8px 0 10px;
            font-size: clamp(28px, 5vw, 44px);
            letter-spacing: -0.02em;
            line-height: 1.1;
        }

        .hero-subtitle {
            color: rgba(255, 255, 255, 0.72);
            margin-bottom: 32px;
            font-size: 16px;
            max-width: 58ch;
        }

        .cta-row {
            display: flex;
            gap: 12px;
            align-items: center;
            flex-wrap: wrap;
        }

        .ghost-btn {
            background: rgba(255, 255, 255, 0.08);
            color: #fff;
            box-shadow: none;
        }

        .ghost-btn:hover {
            box-shadow: none;
            background: rgba(255, 255, 255, 0.14);
        }

        @media (max-width: 600px) {
            .score-panel {
                grid-template-columns: 1fr;
            }

            .quest-card {
                padding: 22px;
            }

            .options-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <div class="game-bg"></div>

    <nav class="spatial-nav glass-panel">
        <div class="nav-brand">
            <a href="/" style="display:flex; align-items:center; gap:12px; text-decoration:none; color:inherit;">
                <img src="/images/logo-icon.png" alt="Logo" style="height:24px;">CitiVoice
            </a>
        </div>
        <div class="nav-links">
            <a href="/places">Места</a>
            <a href="/routes">Маршруты</a>
            <a href="/game" class="active">Игра</a>
            <a href="/map">Карта</a>
        </div>
        <div class="nav-user">
            <a href="<%= locals.user ? '/profile' : '/login' %>" style="color: inherit;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg>
            </a>
        </div>
    </nav>

    <div class="quest-container">
        <div class="score-panel" id="scorePanel" style="display:none;">
            <div class="score-item">
                <span class="score-label">Очки знаний</span>
                <span id="scoreEl" class="score-value">0</span>
            </div>
            <div class="score-item">
                <span class="score-label">Вопрос</span>
                <span id="questionIndexEl" class="score-value">0</span>
            </div>
            <div class="score-item">
                <span class="score-label">Осталось</span>
                <span id="leftCountEl" class="score-value">0</span>
            </div>
            <div class="progress-wrap">
                <div class="progress-track">
                    <div class="progress-fill" id="progressFill"></div>
                </div>
                <div class="progress-caption" id="progressCaption">Прогресс: 0%</div>
            </div>
        </div>

        <div class="quest-card" id="uiContainer">
            <!-- Content dynamically rendered here -->
        </div>
    </div>

    <script>
        const quests = [
            {
                fact: "Оренбург задумывался как окно в Азию и закладывался целых три раза в разных местах! Сначала в 1735 году у слияния рек Орь и Урал, затем в 1739-м в урочище Красная Гора, и наконец, в 1743 году на своем историческом, нынешнем месте.",
                question: "Сколько раз закладывался город Оренбург до того, как остался на нынешнем месте?",
                options: ["Один раз", "Два раза", "Три раза", "Четыре раза"],
                correct: 2
            },
            {
                fact: "Через реку Урал в Оренбурге проходит знаменитый пешеходный мост (Беловка). Он уникален тем, что является символической границей между двумя частями света. Прямо на мосту стоит знак, у которого можно сфотографироваться.",
                question: "Какие части света соединяет знаменитый пешеходный мост в Оренбурге?",
                options: ["Европу и Азию", "Россию и Казахстан", "Европу и Африку", "Север и Юг"],
                correct: 0
            },
            {
                fact: "Оренбургское высшее военное авиационное Краснознаменное училище им. И.С. Полбина выпустило множество выдающихся пилотов. Один из выпускников навсегда вошел в историю человечества 12 апреля 1961 года.",
                question: "Кто из знаменитых людей учился в Оренбургском летном училище?",
                options: ["Валерий Чкалов", "Алексей Леонов", "Юрий Гагарин", "Михаил Громов"],
                correct: 2
            },
            {
                fact: "Оренбургский пуховый платок — один из всемирно известных символов России. Настоящий платок ручной работы паутинной вязки, несмотря на свои большие размеры, удивительно компактен и легок.",
                question: "Через что должен проходить настоящий оренбургский пуховый платок, чтобы доказать свою тонкость?",
                options: ["Через игольное ушко", "Через обручальное кольцо", "Через браслет", "Через горлышко бутылки"],
                correct: 1
            },
            {
                fact: "С 1938 по 1957 год Оренбург носил имя выдающегося советского летчика, который, как ни странно, сам ни разу не был в этом городе. Его имя было присвоено в знак признания государственных заслуг.",
                question: "Какое имя носил город Оренбург в советское время?",
                options: ["Гагарин", "Свердловск", "Чкалов", "Куйбышев"],
                correct: 2
            },
            {
                fact: "Оренбургская область известна солёными озёрами, особенно курортом Соль-Илецк, куда летом приезжают люди со всей страны.",
                question: "Какой курорт Оренбургской области знаменит солёными озёрами?",
                options: ["Бузулук", "Соль-Илецк", "Орск", "Абдулино"],
                correct: 1
            },
            {
                fact: "Национальная деревня в Оренбурге — это культурный комплекс, где представлены подворья разных народов, живущих в регионе.",
                question: "Что можно увидеть в комплексе «Национальная деревня»?",
                options: ["Только музей техники", "Подворья разных народов", "Только спортивные арены", "Только торговый центр"],
                correct: 1
            },
            {
                fact: "Оренбург исторически развивался как торговый центр на стыке европейских и азиатских путей, что сильно повлияло на его архитектуру и культуру.",
                question: "Какая особенность больше всего определяла историческую роль Оренбурга?",
                options: ["Крупный морской порт", "Горный курорт", "Погранично-торговый узел между Европой и Азией", "Центр судостроения"],
                correct: 2
            },
            {
                fact: "Река Урал — одна из немногих крупных рек, которая традиционно считается природной границей между Европой и Азией.",
                question: "Какую символическую роль играет река Урал для Оренбурга?",
                options: ["Граница часовых поясов", "Граница между Европой и Азией", "Граница двух государств", "Граница климатических зон"],
                correct: 1
            },
            {
                fact: "В Оренбурге много зданий конца XIX — начала XX века, сохранивших купеческий стиль и атмосферу старого города.",
                question: "Какой архитектурный пласт хорошо сохранился в центре Оренбурга?",
                options: ["Только конструктивизм 1920-х", "Купеческая застройка XIX—XX веков", "Только стеклянные небоскрёбы", "Средневековые крепости"],
                correct: 1
            },
            {
                fact: "Оренбургская железная дорога в своё время стала важным фактором развития региона и связала город с крупнейшими центрами страны.",
                question: "Что дала Оренбургу железная дорога в историческом развитии?",
                options: ["Сокращение торговли", "Изоляцию от других городов", "Усиление транспортных и экономических связей", "Отказ от промышленности"],
                correct: 2
            },
            {
                fact: "Бузулукский бор в Оренбургской области — уникальный природный массив с реликтовыми сосновыми лесами.",
                question: "Чем известен Бузулукский бор?",
                options: ["Вулканическими озёрами", "Реликтовыми сосновыми лесами", "Пустынными дюнами", "Высокогорными ледниками"],
                correct: 1
            },
            {
                fact: "Оренбург часто называют городом, где встречаются разные культуры, что отражается в кухне, традициях и городских праздниках.",
                question: "В чем чаще всего проявляется культурное многообразие Оренбурга?",
                options: ["Только в спортивных матчах", "В кухне, традициях и праздниках", "Только в языке вывесок", "В отсутствии национальных различий"],
                correct: 1
            },
            {
                fact: "Краеведческие и художественные музеи Оренбурга хранят материалы, связанные с историей края, бытом жителей и развитием искусства.",
                question: "Что в первую очередь можно узнать в музеях Оренбурга?",
                options: ["Только расписание транспорта", "Историю края и культуру региона", "Только прогноз погоды", "Правила дорожного движения"],
                correct: 1
            }
        ];

        let score = 0;
        let availableQuests = [...quests];
        let currentQuest = null;
        let askedCount = 0;

        const uiContainer = document.getElementById('uiContainer');
        const scorePanel = document.getElementById('scorePanel');
        const scoreEl = document.getElementById('scoreEl');
        const questionIndexEl = document.getElementById('questionIndexEl');
        const leftCountEl = document.getElementById('leftCountEl');
        const progressFill = document.getElementById('progressFill');
        const progressCaption = document.getElementById('progressCaption');

        function updateProgressPanel() {
            const total = quests.length;
            const left = availableQuests.length;
            const progressPercent = Math.round((askedCount / total) * 100);

            scoreEl.innerText = score;
            questionIndexEl.innerText = `${askedCount}/${total}`;
            leftCountEl.innerText = left;
            progressFill.style.width = `${progressPercent}%`;
            progressCaption.innerText = `Прогресс: ${progressPercent}%`;
        }

        function animateTransition(renderFn) {
            uiContainer.classList.add('fade');
            setTimeout(() => {
                renderFn();
                uiContainer.classList.remove('fade');
            }, 400);
        }

        function renderStartScreen() {
            uiContainer.innerHTML = `
                <div class="badge">Локальный Квест</div>
                <h1 class="hero-title">Исследователь Оренбурга</h1>
                <p class="hero-subtitle">
                    Красивый мини-квиз о городе: факты, вопросы и быстрый набор очков. В этой версии больше раундов, поэтому можно играть дольше.
                </p>
                <div class="cta-row">
                    <button class="btn-action" onclick="nextQuest()">Начать квест</button>
                    <button class="btn-action ghost-btn" onclick="window.location.href='/map'">Открыть карту</button>
                </div>
            `;
        }

        function nextQuest() {
            scorePanel.style.display = 'block';
            if (availableQuests.length === 0) {
                animateTransition(renderFinishScreen);
                return;
            }
            // Выбираем случайный квест
            const randomIndex = Math.floor(Math.random() * availableQuests.length);
            currentQuest = availableQuests[randomIndex];
            availableQuests.splice(randomIndex, 1); // Убираем из массива
            askedCount += 1;
            updateProgressPanel();

            animateTransition(() => renderFactScreen(currentQuest));
        }

        function renderFactScreen(quest) {
            uiContainer.innerHTML = `
                <div class="badge">Интересный факт</div>
                <div class="fact-text">${quest.fact}</div>
                <button class="btn-action" onclick="showQuestion()">Понятно, к вопросу!</button>
            `;
        }

        window.showQuestion = function () {
            animateTransition(() => {
                let optionsHtml = '';
                currentQuest.options.forEach((opt, index) => {
                    optionsHtml += `<button class="option-btn" onclick="checkAnswer(${index}, this)">${opt}</button>`;
                });

                uiContainer.innerHTML = `
                    <div class="badge">Вопрос</div>
                    <div class="question-text">${currentQuest.question}</div>
                    <div class="options-grid">
                        ${optionsHtml}
                    </div>
                `;
            });
        }

        window.checkAnswer = function (selectedIndex, btnElement) {
            // Отключаем все кнопки
            const allBtns = document.querySelectorAll('.option-btn');
            allBtns.forEach(btn => btn.disabled = true);

            const isCorrect = selectedIndex === currentQuest.correct;

            if (isCorrect) {
                btnElement.classList.add('correct');
                score += 100;
                updateProgressPanel();
                // Save EXP to profile
                fetch('/api/user/exp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ expEarned: 100 })
                }).catch(err => console.error(err));
            } else {
                btnElement.classList.add('wrong');
                // Подсвечиваем правильный
                allBtns[currentQuest.correct].classList.add('correct');
            }

            setTimeout(() => {
                animateTransition(() => renderResultScreen(isCorrect));
            }, 1200);
        }

        function renderResultScreen(isCorrect) {
            if (isCorrect) {
                uiContainer.innerHTML = `
                    <h2 class="result-message success">Правильно!</h2>
                    <p class="result-subtext">+100 очков знаний в вашу копилку.</p>
                    <button class="btn-action" onclick="nextQuest()">Следующий факт</button>
                `;
            } else {
                uiContainer.innerHTML = `
                    <h2 class="result-message fail">Ошибка</h2>
                    <p class="result-subtext">Ничего страшного, зато теперь вы точно знаете правильный ответ!</p>
                    <button class="btn-action" onclick="nextQuest()">Продолжить</button>
                `;
            }
        }

        function renderFinishScreen() {
            uiContainer.innerHTML = `
                <div class="badge">Квест завершен</div>
                <h2 style="color: #E0FF4F; margin-bottom: 10px;">Поздравляем!</h2>
                <p style="color: rgba(255,255,255,0.7); font-size: 18px; margin-bottom: 30px;">
                    Вы прошли <b style="color:white;">${quests.length}</b> раундов и расшифровали все факты об Оренбурге. Ваш итоговый счет: <b style="color:white;">${score}</b> очков.
                </p>
                <div style="display:flex; justify-content:center; gap: 16px;">
                    <button class="btn-action" style="background: rgba(255,255,255,0.1); color: white; box-shadow: none;" onclick="window.location.href='/'">На главную</button>
                    <button class="btn-action" onclick="location.reload()">Сыграть еще раз</button>
                </div>
            `;
        }

        // Инициализация
        updateProgressPanel();
        renderStartScreen();
    </script>
</body>

</html>