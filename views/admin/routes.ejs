<%- include('_header', { pageTitle: 'Маршруты' }) %>

    <div class="admin-header">
        <h1>Маршруты</h1>
        <p>Создавайте маршруты и привязывайте к ним места.</p>
    </div>

    <div class="admin-card">
        <div class="admin-card-header">
            <h2>Все маршруты (<%= routes.length %>)</h2>
            <a href="/admin/routes/new" class="btn btn-primary btn-sm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Добавить
            </a>
        </div>
        <% if (routes.length===0) { %>
            <div style="text-align: center; padding: 60px; color: rgba(255,255,255,0.3); font-size: 15px;">Маршрутов
                пока нет. Создайте первый!</div>
            <% } else { %>
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Название</th>
                            <th>Тип</th>
                            <th>Длина</th>
                            <th>Время</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% routes.forEach((route, i)=> { %>
                            <tr>
                                <td style="color: rgba(255,255,255,0.3);">
                                    <%= route.id %>
                                </td>
                                <td><strong>
                                        <%= route.title %>
                                    </strong>
                                    <% if (route.description) { %>
                                        <div style="font-size:12px; color:rgba(255,255,255,0.35); margin-top:2px;">
                                            <%= route.description.slice(0, 60) %>
                                                <%= route.description.length> 60 ? '…' : '' %>
                                        </div>
                                        <% } %>
                                </td>
                                <td><span
                                        style="background: rgba(255,255,255,0.07); padding: 3px 10px; border-radius: 8px; font-size: 12px;">
                                        <%= route.type || '—' %>
                                    </span></td>
                                <td>
                                    <%= route.distance ? route.distance : '—' %>
                                </td>
                                <td>
                                    <%= route.duration ? route.duration : '—' %>
                                </td>
                                <td>
                                    <div style="display: flex; gap: 8px;">
                                        <a href="/admin/routes/<%= route.id %>/edit"
                                            class="btn btn-ghost btn-sm">Ред.</a>
                                        <form method="POST" action="/admin/routes/<%= route.id %>/delete"
                                            onsubmit="return confirm('Удалить маршрут «<%= route.title %>»?')"
                                            style="margin: 0;">
                                            <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
                <% } %>
    </div>

    <%- include('_footer') %>